{
  "version": "1.0.0",
  "lastUpdated": "2026-03-04",
  "description": "Technical requirements specification for NanoRemit Dashboard, Mint, and Vault pages",
  "pages": {
    "dashboard": {
      "path": "/dashboard",
      "requiredConnections": ["wallet"],
      "dataRequirements": {
        "userScore": {
          "source": "useScore hook",
          "endpoint": "Backend API /score",
          "fields": {
            "tier": {
              "type": "number",
              "range": "0-3",
              "description": "Current credit tier of user"
            },
            "derivedTier": {
              "type": "number",
              "range": "0-3",
              "description": "Tier user qualifies for based on repayment history"
            },
            "needsUpgrade": {
              "type": "boolean",
              "description": "Flag indicating if user qualifies for tier upgrade"
            },
            "maxLTV": {
              "type": "number",
              "unit": "percentage",
              "description": "Maximum loan-to-value ratio for current tier"
            },
            "apr": {
              "type": "number",
              "unit": "percentage",
              "description": "Annual percentage rate for current tier"
            },
            "repaymentsToNextTier": {
              "type": "number|null",
              "description": "Number of qualifying repayments needed to reach next tier"
            },
            "collateral": {
              "type": "string",
              "format": "bigint",
              "unit": "NanoUSD wei",
              "description": "Total collateral value deposited"
            },
            "debt": {
              "type": "string",
              "format": "bigint",
              "unit": "NanoUSD wei",
              "description": "Current outstanding debt"
            },
            "maxBorrow": {
              "type": "string",
              "format": "bigint",
              "unit": "NanoUSD wei",
              "description": "Maximum borrowing capacity based on collateral and tier"
            },
            "deposited": {
              "type": "number",
              "description": "Number of receipt NFTs deposited as collateral"
            },
            "score": {
              "type": "number",
              "description": "Total count of qualifying repayments made"
            }
          }
        },
        "vaultTokens": {
          "source": "useVaultTokens hook",
          "fields": {
            "depositedTokenIds": {
              "type": "array",
              "items": "bigint",
              "description": "Array of NFT token IDs deposited in vault"
            },
            "nanoUsdBalance": {
              "type": "bigint",
              "unit": "wei",
              "description": "User's NanoUSD token balance"
            }
          }
        }
      },
      "calculations": {
        "availableToBorrow": {
          "formula": "maxBorrow - debt",
          "condition": "if result < 0, return 0",
          "type": "bigint"
        },
        "tierName": {
          "mapping": {
            "0": "Starter",
            "1": "Bronze",
            "2": "Silver",
            "3": "Gold"
          }
        }
      },
      "features": {
        "tierDisplay": {
          "requirements": [
            "Display current tier name and level",
            "Show LTV and APR badges",
            "Color-code based on tier level (tier 3: success, tier 2: warning, default: neutral)"
          ]
        },
        "upgradeNotification": {
          "condition": "needsUpgrade === true",
          "requirements": [
            "Display alert showing derivedTier user qualifies for",
            "Include upgrade call-to-action"
          ]
        },
        "nextTierProgress": {
          "condition": "repaymentsToNextTier > 0",
          "requirements": [
            "Display count of remaining qualifying repayments",
            "Show progress toward next tier"
          ]
        },
        "maxTierIndicator": {
          "condition": "tier >= 3",
          "requirements": ["Display maximum tier reached message"]
        },
        "statsGrid": {
          "cards": [
            {
              "label": "Deposited Receipts",
              "primaryValue": "deposited count",
              "secondaryValue": "collateral in NanoUSD with token formatting"
            },
            {
              "label": "Outstanding Debt",
              "primaryValue": "debt with token formatting",
              "secondaryValue": "maxBorrow with token formatting"
            },
            {
              "label": "Available to Borrow",
              "primaryValue": "calculated available with token formatting",
              "secondaryValue": "conditional message based on availability"
            },
            {
              "label": "NanoUSD Balance",
              "primaryValue": "nanoUsdBalance with token formatting",
              "secondaryValue": "Available for repayment"
            }
          ]
        },
        "quickActions": {
          "links": [
            {
              "label": "Mint Receipt",
              "destination": "/mint",
              "alwaysVisible": true
            },
            {
              "label": "Deposit & Borrow",
              "destination": "/vault",
              "alwaysVisible": true
            },
            {
              "label": "Repay Debt",
              "destination": "/vault?tab=repay",
              "condition": "debt > 0"
            }
          ]
        },
        "depositedTokensList": {
          "condition": "depositedTokenIds.length > 0",
          "requirements": [
            "Display list of deposited token IDs",
            "Format as #<tokenId>"
          ]
        }
      },
      "stateHandling": {
        "notConnected": {
          "action": "Display wallet connection prompt"
        },
        "loading": {
          "condition": "score.isLoading || tokens.isLoading",
          "action": "Display loading indicator"
        },
        "error": {
          "condition": "score.isError || !score.data",
          "action": "Display error message with backend unavailable notice"
        }
      },
      "formatting": {
        "tokenAmounts": {
          "function": "formatToken",
          "decimals": 18,
          "output": "human-readable decimal"
        },
        "tierNames": {
          "function": "tierName",
          "mapping": "See calculations.tierName"
        }
      }
    },
    "mint": {
      "path": "/mint",
      "requiredConnections": ["wallet"],
      "modes": {
        "demo": {
          "requirements": [
            "Use predefined IPFS URI",
            "Fixed notional value: 100 NanoUSD",
            "Recipient defaults to connected wallet address",
            "Single-click mint without upload"
          ],
          "constants": {
            "demoUri": "ipfs://bafkreihdwdcefgh4dqkjv67uzcmw7ojee6xedzdetojuzjevtenosa7777",
            "notionalValue": 100
          }
        },
        "upload": {
          "requirements": [
            "File upload with validation",
            "Metadata capture form",
            "IPFS upload via backend API",
            "Contract minting after successful upload"
          ]
        }
      },
      "fileValidation": {
        "acceptedTypes": ["application/pdf"],
        "maxSize": 10485760,
        "maxSizeDisplay": "10MB",
        "validation": [
          "Check file size <= maxSize",
          "Verify file type is PDF",
          "Display error toast on validation failure"
        ]
      },
      "formFields": {
        "required": {
          "file": {
            "type": "File",
            "accept": ".pdf,application/pdf",
            "validation": "See fileValidation"
          },
          "invoiceNumber": {
            "type": "string",
            "minLength": 3,
            "maxLength": 50,
            "pattern": "letters, numbers, hyphens only",
            "placeholder": "INV-2026-001"
          },
          "dueDate": {
            "type": "date",
            "validation": "must be future date",
            "format": "ISO date string"
          },
          "counterparty": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "placeholder": "Acme Corp"
          },
          "amount": {
            "type": "string",
            "format": "numeric",
            "decimals": 2,
            "validation": "numbers and decimal point only",
            "placeholder": "1000.50"
          },
          "currency": {
            "type": "string",
            "format": "ISO 4217 code",
            "default": "USD",
            "options": "See currencyOptions"
          },
          "receiver": {
            "type": "string",
            "description": "Name of person receiving payment",
            "placeholder": "John Doe"
          }
        },
        "optional": {
          "senderName": {
            "type": "string",
            "placeholder": "Your name"
          },
          "receiverName": {
            "type": "string",
            "description": "Recipient's full name",
            "placeholder": "Recipient's full name"
          },
          "note": {
            "type": "string",
            "maxLength": 500,
            "placeholder": "Additional notes",
            "characterCounter": true
          }
        }
      },
      "currencyOptions": {
        "source": "currency-codes npm package",
        "popularCurrencies": [
          "USD", "EUR", "GBP", "JPY", "CHF", "CAD", "AUD", "NZD",
          "INR", "CNY", "KRW", "SGD", "HKD", "MXN", "BRL", "ZAR",
          "NGN", "KES", "GHS", "UGX", "TZS", "RWF", "ETB", "XOF", "XAF"
        ],
        "allCurrencies": "cc.codes() - all ISO 4217 codes",
        "grouping": [
          {
            "label": "Popular",
            "codes": "popularCurrencies array"
          },
          {
            "label": "All Currencies",
            "codes": "remaining ISO 4217 codes"
          }
        ]
      },
      "ipfsUpload": {
        "endpoint": "Backend API /pin",
        "method": "POST",
        "requestFormat": "multipart/form-data",
        "requestFields": {
          "file": "File object",
          "invoiceNumber": "string",
          "dueDate": "string",
          "counterparty": "string",
          "amount": "string",
          "currency": "string",
          "receiver": "string",
          "senderName": "string (optional)",
          "receiverName": "string (optional)",
          "note": "string (optional)"
        },
        "response": {
          "ipfsUri": {
            "type": "string",
            "format": "ipfs://<CID>"
          },
          "fileHash": {
            "type": "string",
            "format": "keccak256 hash",
            "description": "Hash for file authenticity verification"
          }
        },
        "stateManagement": {
          "isUploading": "boolean flag during upload",
          "uploadedUri": "stored IPFS URI after success",
          "fileHash": "stored hash for display"
        },
        "errorHandling": {
          "displayToast": true,
          "logInDev": true,
          "resetState": false
        }
      },
      "minting": {
        "contract": "RemittanceReceipt",
        "function": "mint",
        "hook": "useMintReceipt",
        "parameters": {
          "to": "address - recipient wallet address",
          "tokenUri": "string - IPFS URI (uploadedUri || DEMO_URI)"
        },
        "workflow": [
          "User clicks mint button",
          "Transaction submitted to chain",
          "Wait for confirmation",
          "Display success state"
        ],
        "states": {
          "isPending": "transaction submitted, waiting for inclusion",
          "isConfirming": "transaction included, waiting for confirmations",
          "isConfirmed": "transaction confirmed",
          "error": "transaction error object",
          "hash": "transaction hash"
        }
      },
      "features": {
        "modeToggle": {
          "options": ["demo", "upload"],
          "default": "demo"
        },
        "filePreview": {
          "requirements": [
            "Display selected filename",
            "Show file size in KB",
            "Allow reselection"
          ]
        },
        "uploadProgress": {
          "requirements": [
            "Show loading state during IPFS upload",
            "Display success message with IPFS URI",
            "Show file hash for verification"
          ]
        },
        "mintButton": {
          "states": [
            "Upload to IPFS (before upload)",
            "Uploading... (during upload)",
            "Mint Receipt (after upload or in demo mode)",
            "Minting... (during transaction)",
            "Receipt minted! (after success)"
          ],
          "disabledConditions": [
            "In upload mode: missing required fields",
            "During upload: isUploading === true",
            "During minting: isPending || isConfirming"
          ]
        }
      },
      "stateHandling": {
        "notConnected": {
          "action": "Display wallet connection prompt"
        }
      },
      "constants": {
        "maxFileSize": 10485760,
        "notionalValue": 100,
        "acceptedFileTypes": ["application/pdf"]
      }
    },
    "vault": {
      "path": "/vault",
      "requiredConnections": ["wallet"],
      "tabs": {
        "deposit": {
          "id": "deposit",
          "label": "Deposit",
          "dataRequirements": {
            "tokenId": {
              "type": "bigint",
              "source": "user input",
              "validation": "must be positive integer"
            },
            "nftApproval": {
              "type": "boolean",
              "source": "useNftApprovalForAll hook",
              "description": "Whether vault is approved to transfer user's NFTs"
            },
            "depositedTokenIds": {
              "type": "array<bigint>",
              "source": "useVaultTokens hook"
            }
          },
          "workflow": {
            "notApproved": {
              "steps": [
                "Display approval button",
                "User approves NFTs for vault",
                "Wait for confirmation",
                "Enable deposit functionality"
              ]
            },
            "approved": {
              "steps": [
                "User enters token ID",
                "User clicks deposit",
                "Transaction submitted",
                "NFT transferred to vault",
                "Collateral value updated"
              ]
            }
          },
          "contractInteractions": {
            "approval": {
              "contract": "RemittanceReceipt",
              "function": "setApprovalForAll",
              "hook": "useApproveNfts",
              "parameters": {
                "operator": "vault contract address",
                "approved": true
              }
            },
            "deposit": {
              "contract": "NanoRemitVault",
              "function": "deposit",
              "hook": "useDeposit",
              "parameters": {
                "tokenId": "bigint"
              },
              "requirements": [
                "NFT approval must be granted",
                "User must own the token",
                "Token must not already be deposited"
              ]
            }
          },
          "features": {
            "tokenIdInput": {
              "type": "number",
              "min": 1,
              "placeholder": "e.g. 1"
            },
            "depositedTokensDisplay": {
              "condition": "depositedTokenIds.length > 0",
              "format": "Comma-separated list of #<tokenId>"
            }
          },
          "businessLogic": {
            "collateralValue": "Each receipt = 100 NanoUSD collateral"
          }
        },
        "borrow": {
          "id": "borrow",
          "label": "Borrow",
          "dataRequirements": {
            "amount": {
              "type": "bigint",
              "source": "user input",
              "unit": "wei",
              "validation": "must be > 0 and <= available"
            },
            "maxBorrow": {
              "type": "bigint",
              "source": "useScore hook",
              "description": "Maximum borrowing capacity"
            },
            "debt": {
              "type": "bigint",
              "source": "useScore hook",
              "description": "Current debt"
            },
            "apr": {
              "type": "number",
              "source": "useScore hook",
              "unit": "percentage"
            },
            "maxLTV": {
              "type": "number",
              "source": "useScore hook",
              "unit": "percentage"
            }
          },
          "calculations": {
            "available": {
              "formula": "maxBorrow - debt",
              "condition": "if result < 0, return 0"
            }
          },
          "contractInteractions": {
            "borrow": {
              "contract": "NanoRemitVault",
              "function": "borrow",
              "hook": "useBorrow",
              "parameters": {
                "amount": "bigint - amount in wei"
              },
              "requirements": [
                "User must have sufficient collateral",
                "Amount must not exceed available borrowing capacity",
                "Must respect tier-based LTV limits"
              ]
            }
          },
          "features": {
            "amountInput": {
              "type": "number",
              "min": 0,
              "step": "any",
              "placeholder": "0.00",
              "suffix": "NUSD",
              "parsing": "parseUnits(input, 18)"
            },
            "tierDisplay": {
              "badges": [
                {
                  "label": "LTV percentage",
                  "variant": "success"
                },
                {
                  "label": "APR percentage",
                  "variant": "warning"
                }
              ],
              "availableAmount": "formatted available to borrow"
            },
            "maxButton": {
              "action": "Set amount to available",
              "formula": "formatUnits(available, 18)"
            },
            "watchAsset": {
              "condition": "borrow.isConfirmed && canWatch",
              "action": "Add NanoUSD token to wallet",
              "hook": "useWatchNanoUsd"
            }
          },
          "businessLogic": {
            "tierBasedLimits": "LTV and APR determined by user's tier",
            "interestAccrual": "Interest accrues on borrowed amount"
          }
        },
        "repay": {
          "id": "repay",
          "label": "Repay",
          "dataRequirements": {
            "amount": {
              "type": "bigint",
              "source": "user input",
              "unit": "wei",
              "validation": "must be > 0"
            },
            "debt": {
              "type": "bigint",
              "source": "useScore hook",
              "description": "Current outstanding debt including interest"
            },
            "nanoUsdBalance": {
              "type": "bigint",
              "source": "useVaultTokens hook",
              "description": "User's NanoUSD balance"
            },
            "nanoUsdAllowance": {
              "type": "bigint",
              "source": "useNanoUsdAllowance hook",
              "description": "Amount vault is approved to spend"
            }
          },
          "calculations": {
            "maxRepayAmount": {
              "formula": "nanoUsdBalance >= debt ? nanoUsdBalance : debt",
              "description": "Maximum amount user can repay"
            },
            "needsApproval": {
              "formula": "allowance < amount"
            },
            "insufficientBalance": {
              "formula": "nanoUsdBalance < debt && debt > 0",
              "calculation": "debt - nanoUsdBalance"
            }
          },
          "contractInteractions": {
            "approval": {
              "contract": "NanoUSD",
              "function": "approve",
              "hook": "useApproveNanoUsd",
              "parameters": {
                "spender": "vault contract address",
                "amount": "max uint256"
              }
            },
            "repay": {
              "contract": "NanoRemitVault",
              "function": "repay",
              "hook": "useRepay",
              "parameters": {
                "amount": "bigint - amount in wei"
              },
              "requirements": [
                "User must have NanoUSD approval",
                "User must have sufficient NanoUSD balance",
                "Amount must be > 0"
              ]
            }
          },
          "features": {
            "debtDisplay": {
              "currentDebt": "formatted debt amount",
              "userBalance": "formatted nanoUsdBalance",
              "insufficientWarning": {
                "condition": "nanoUsdBalance < debt && debt > 0",
                "message": "Shows required additional NUSD amount"
              }
            },
            "amountInput": {
              "type": "number",
              "min": 0,
              "step": "any",
              "placeholder": "0.00",
              "suffix": "NUSD",
              "parsing": "parseUnits(input, 18)"
            },
            "maxButton": {
              "action": "Set to maxRepayAmount",
              "behavior": "Uses raw bigint to avoid precision loss",
              "display": "Shows debt amount in input field"
            },
            "approvalWorkflow": {
              "condition": "needsApproval === true",
              "step1": "Approve NanoUSD spending",
              "step2": "Enable repay button after approval"
            }
          },
          "businessLogic": {
            "qualifyingRepayments": "Repayments >= 10% of outstanding debt count toward tier upgrades",
            "interestIncluded": "Contract caps repayment to actual debt including accrued interest",
            "maxRepayHandling": "When clicking Max, send maxRepayAmount to ensure full repayment"
          }
        },
        "withdraw": {
          "id": "withdraw",
          "label": "Withdraw",
          "dataRequirements": {
            "tokenId": {
              "type": "bigint",
              "source": "user input",
              "validation": "must be positive integer"
            },
            "debt": {
              "type": "bigint",
              "source": "useScore hook",
              "description": "Current debt must be 0 to withdraw"
            },
            "depositedTokenIds": {
              "type": "array<bigint>",
              "source": "useVaultTokens hook"
            }
          },
          "contractInteractions": {
            "withdraw": {
              "contract": "NanoRemitVault",
              "function": "withdraw",
              "hook": "useWithdraw",
              "parameters": {
                "tokenId": "bigint"
              },
              "requirements": [
                "User must have zero outstanding debt",
                "Token must be deposited by user",
                "User must own the position"
              ]
            }
          },
          "features": {
            "debtCheck": {
              "condition": "debt > 0",
              "action": "Display error message and disable withdraw",
              "message": "Must repay all debt before withdrawing"
            },
            "tokenIdInput": {
              "type": "number",
              "min": 1,
              "placeholder": "e.g. 1"
            },
            "tokenSelector": {
              "condition": "depositedTokenIds.length > 0",
              "requirements": [
                "Display clickable token ID badges",
                "Highlight selected token",
                "Auto-populate input on click"
              ]
            }
          },
          "businessLogic": {
            "zeroDebtRequired": "Cannot withdraw any collateral while debt exists",
            "nftReturn": "NFT transferred back to user wallet"
          }
        }
      },
      "navigation": {
        "defaultTab": "deposit",
        "urlParameter": "tab",
        "validTabs": ["deposit", "borrow", "repay", "withdraw"],
        "syncBehavior": "Tab syncs with URL parameter on mount and parameter change"
      },
      "sharedComponents": {
        "txButton": {
          "props": {
            "label": "string - button text",
            "loadingLabel": "string - text during transaction",
            "onClick": "function - transaction trigger",
            "isPending": "boolean - transaction submitted",
            "isConfirming": "boolean - awaiting confirmations",
            "isConfirmed": "boolean - transaction complete",
            "error": "Error object or null",
            "hash": "string - transaction hash",
            "disabled": "boolean - button disabled state"
          }
        }
      },
      "stateHandling": {
        "notConnected": {
          "action": "Display wallet connection prompt"
        }
      },
      "formatting": {
        "tokenAmounts": {
          "function": "formatToken",
          "decimals": 18,
          "parseFunction": "parseUnits/formatUnits from viem"
        }
      }
    }
  },
  "sharedIntegrations": {
    "web3": {
      "provider": "wagmi",
      "hooks": {
        "useAccount": "Get connected wallet address and connection status",
        "useScore": "Fetch user credit score and tier data from backend API",
        "useVaultTokens": "Get deposited token IDs and NanoUSD balance",
        "useNanoUsdAllowance": "Check NanoUSD spending approval",
        "useNftApprovalForAll": "Check NFT transfer approval for vault",
        "useDeposit": "Deposit receipt NFT into vault",
        "useApproveNfts": "Approve vault to transfer NFTs",
        "useBorrow": "Borrow NanoUSD against collateral",
        "useRepay": "Repay NanoUSD debt",
        "useApproveNanoUsd": "Approve vault to spend NanoUSD",
        "useWithdraw": "Withdraw receipt NFT from vault",
        "useWatchNanoUsd": "Add NanoUSD token to wallet",
        "useMintReceipt": "Mint new receipt NFT"
      },
      "contracts": {
        "RemittanceReceipt": {
          "type": "ERC-721",
          "functions": [
            "mint(address to, string tokenUri)",
            "setApprovalForAll(address operator, bool approved)"
          ]
        },
        "NanoRemitVault": {
          "functions": [
            "deposit(uint256 tokenId)",
            "borrow(uint256 amount)",
            "repay(uint256 amount)",
            "withdraw(uint256 tokenId)"
          ]
        },
        "NanoUSD": {
          "type": "ERC-20",
          "functions": [
            "approve(address spender, uint256 amount)",
            "allowance(address owner, address spender)"
          ]
        }
      }
    },
    "backend": {
      "baseUrl": "Configured in environment",
      "endpoints": {
        "/score": {
          "method": "GET",
          "queryParams": {
            "address": "wallet address"
          },
          "response": "See dashboard.dataRequirements.userScore",
          "errorHandling": "Graceful fallback with error message"
        },
        "/pin": {
          "method": "POST",
          "contentType": "multipart/form-data",
          "body": "See mint.ipfsUpload.requestFields",
          "response": "See mint.ipfsUpload.response",
          "errorHandling": "Display toast message"
        }
      },
      "rateLimit": "Configured in backend",
      "authentication": "None required for current version"
    },
    "ipfs": {
      "gateway": "Configurable",
      "pinning": "Via backend API",
      "uriFormat": "ipfs://<CID>",
      "metadata": "Includes invoice details and file hash"
    }
  },
  "utilities": {
    "formatting": {
      "formatToken": {
        "description": "Format bigint token amounts to human-readable decimals",
        "decimals": 18,
        "location": "@/utils/format"
      },
      "tierName": {
        "description": "Convert tier number to display name",
        "mapping": {
          "0": "Starter",
          "1": "Bronze",
          "2": "Silver",
          "3": "Gold"
        },
        "location": "@/utils/format"
      }
